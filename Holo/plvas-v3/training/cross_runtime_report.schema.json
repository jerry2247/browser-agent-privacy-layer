{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plva.local/schemas/cross-runtime-report.schema.json",
  "title": "PLVA tagger cross-runtime report",
  "type": "object",
  "required": ["schema_version", "model_sha256", "backends"],
  "properties": {
    "schema_version": { "const": 1 },
    "model_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "golden_vectors_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "backends": {
      "type": "object",
      "required": ["node", "wasm", "webgpu"],
      "properties": {
        "node": { "$ref": "#/$defs/backend" },
        "wasm": { "$ref": "#/$defs/backend" },
        "webgpu": {
          "allOf": [
            { "$ref": "#/$defs/backend" },
            {
              "required": ["provider_trace"],
              "properties": {
                "provider_trace": {
                  "type": "object",
                  "required": ["verified", "fallback_nodes"],
                  "properties": {
                    "verified": { "const": true },
                    "fallback_nodes": { "type": "integer", "minimum": 0 },
                    "fallback_measured": { "type": "boolean" },
                    "method": { "type": "string", "minLength": 1 }
                  },
                  "additionalProperties": true
                }
              }
            }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "backend": {
      "type": "object",
      "required": ["passed", "package", "package_version", "vectors_checked"],
      "properties": {
        "passed": { "const": true },
        "package": { "type": "string", "minLength": 1 },
        "package_version": { "const": "1.27.0" },
        "vectors_checked": { "type": "integer", "minimum": 1 },
        "execution_providers_requested": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "failed_vector_ids": { "type": "array", "maxItems": 0 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
