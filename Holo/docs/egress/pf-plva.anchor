# PLVA egress anchor — enforce "only the PLVA proxy may reach the provider".
#
# This is the macOS substitute for OpenShell's per-sandbox network namespace
# (see docs/decisions/0001-openshell-sec7-egress-topology.md): pf cannot match
# by process, but it can match by socket-owning user, so the enforcing variant
# runs the proxy as a dedicated role user.
#
# One-time setup (operator, sudo; see docs/egress/bootstrap-pf.md first):
#   sudo sysadminctl -addUser _plvaproxy -shell /usr/bin/false   # role user
#   sudo pfctl -a plva -f docs/egress/pf-plva.anchor             # load anchor
#   sudo pfctl -e                                                # enable pf
#
# Before EVERY run (pf resolves the table hostname only at load time, so a
# reload closes any CDN IP-churn gap):
#   sudo pfctl -a plva -f docs/egress/pf-plva.anchor
#
# Then start the proxy as the role user so rule 2 matches its sockets
# (the role user needs read/execute access to the repo's .venv and .env):
#   sudo -u _plvaproxy API_KEY=... .venv/bin/plva-proxy
#
# Inspect:  sudo pfctl -a plva -sr
# Remove:   sudo pfctl -a plva -F rules

table <inference_providers> persist { api.overshoot.ai, api.hcompany.ai }

# 1) No process on this host may open a TCP connection to the provider...
block return out proto tcp to <inference_providers> port 443

# 2) ...except sockets owned by the proxy's dedicated role user.
pass out proto tcp to <inference_providers> port 443 user _plvaproxy keep state
